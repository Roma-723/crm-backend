generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String       @id @default(uuid())
  name       String
  email      String       @unique
  password   String
  phone      String?
  age        Int?
  avatar     String?
  role       String       @default("user")
  salary     Float        @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  attendance Attendance[]
  bonuses    Bonus[]
  penalties  Penalty[]

  // Business relations
  nalogs    Nalog[]
  arendas   Arenda[]
  incomes   Income[]
  expenses  Expense[]
  materials Material[]
  utilities Utility[]
  avans     Avans[]

  // Payroll relations
  payrollRecords PayrollRecord[]

  // Project relations
  projectUsers  ProjectUser[]
  assignedTasks Task[]        @relation("assignedTasks")
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String
  date      String
  status    String
  comment   String?
  reason    String?
  lateHours Float    @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bonus {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  reason    String
  comment   String?
  date      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Penalty {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  reason    String
  comment   String?
  date      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  code      String
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// === BUSINESS MODELS ===

model Nalog {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime
  type      String
  amount    Float
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Arenda {
  id        String   @id @default(uuid())
  userId    String
  month     Int
  year      Int
  amount    Float
  object    String
  status    String   @default("pending") // paid | pending | overdue
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Income {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  category    String
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  category    String
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Material {
  id        String   @id @default(uuid())
  userId    String
  name      String
  quantity  Float
  price     Float
  date      DateTime
  supplier  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Utility {
  id        String   @id @default(uuid())
  userId    String
  month     Int
  year      Int
  type      String
  amount    Float
  meter     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Avans {
  id         String   @id @default(uuid())
  userId     String
  employeeId String?
  date       DateTime
  person     String
  amount     Float
  purpose    String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayrollRecord {
  id          String   @id @default(uuid())
  userId      String
  totalSalary Float
  paidAmount  Float
  month       String
  notes       String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WindowPrice {
  id           String   @id
  lPrice       Float    @default(0)
  tPrice       Float    @default(0)
  zPrice       Float    @default(0)
  glassPrice   Float    @default(0)
  shtapikPrice Float    @default(0)
  updatedAt    DateTime @updatedAt
}

model Project {
  id         String        @id @default(uuid())
  name       String
  clientName String
  startDate  String
  endDate    String?
  status     String        @default("active")
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  tasks      Task[]
  users      ProjectUser[]
}

model Task {
  id             String   @id @default(uuid())
  projectId      String
  title          String
  area           Float
  pricePerM2     Float
  startDate      String
  deadline       String?
  done           Boolean  @default(false)
  assignedUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedUser   User?    @relation("assignedTasks", fields: [assignedUserId], references: [id], onDelete: SetNull)
}

model ProjectUser {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}
